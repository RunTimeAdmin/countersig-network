# Countersig oracle — Robinhood Chain testnet (46630).
# Sepolia (11155111) still works: use deployments/11155111.json instead.
# See docs/robinhood-chain.md

# Public RH testnet RPC is rate-limited; prefer Alchemy robinhood-testnet for production indexing.
RPC_URL=https://rpc.testnet.chain.robinhood.com

# Oracle wallet private key — must have ORACLE_ROLE on CountersigReputation
# Generate a fresh wallet: cast wallet new
# Fund with Robinhood testnet ETH: https://faucet.testnet.chain.robinhood.com
ORACLE_PRIVATE_KEY=0x...

# Contract addresses — Robinhood testnet (deployments/46630.json)
IDENTITY_ADDRESS=0xCCF2Fd69c07EDFbc3C215cfD31e2F20FC208A16C
REPUTATION_ADDRESS=0xbB0c9C2DF28af31905dEfEa04c80372C0909f1bF

# Epoch interval. Set to 1 for testnet fast feedback, 24 for production cadence.
EPOCH_HOURS=1

# HTTP bind address — defaults to 127.0.0.1 (localhost only) for bare-metal runs.
# In Docker set HOST=0.0.0.0: docker-compose.oracle.yml publishes the port as
# 127.0.0.1:3030 (that mapping is what restricts access to the host), and the app
# must bind 0.0.0.0 INSIDE the container or the published port can't reach it.
# Only expose beyond localhost with ORACLE_ADMIN_TOKEN set.
HOST=127.0.0.1

# HTTP port
PORT=3030

# Block to start scanning AgentRegistered events from (RH deploy ~90338571).
FROM_BLOCK=90338550

# Max blocks per eth_getLogs call.
LOG_CHUNK_SIZE=2000

# Bearer token protecting /attest, /flag, and /epoch from public writes.
# If unset, those endpoints are open (fine for local testing, not for a public VPS —
# the server logs a warning at startup). Generate with: openssl rand -hex 32
ORACLE_ADMIN_TOKEN=

# Optional: CountersigEpochFees registry address. When set AND its on-chain
# epochFee > 0, the oracle only scores agents with fee coverage and charges one
# epoch fee per agent it scores (tokenomics §4). Leave unset to score every agent
# (testnet default). The oracle wallet must hold ORACLE_ROLE on the registry.
FEE_REGISTRY_ADDRESS=

# Optional: ERC-8004 registries for the externalScore factor (max 15). When all
# three are set, an agent LINKED to an ERC-8004 identity it owns (POST /link)
# gets an external-trust score computed from its 8004 feedback (see external.js).
# Unset leaves externalScore at 0. Canonical testnet singletons on Base Sepolia:
EXTERNAL_RPC=https://sepolia.base.org
EXTERNAL_IDENTITY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
EXTERNAL_REPUTATION_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
