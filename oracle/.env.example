# RPC endpoint for the target chain (e.g. Sepolia)
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Private key of the account holding ORACLE_ROLE on CountersigReputation
ORACLE_PRIVATE_KEY=0x...

# Deployed proxy addresses (from deployments/11155111.json after forge script)
IDENTITY_ADDRESS=0x...
REPUTATION_ADDRESS=0x...

# How often to run the scoring epoch (default: 24 hours)
EPOCH_HOURS=24

# HTTP port for the attestation intake API (default: 3030)
PORT=3030
