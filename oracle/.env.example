# Sepolia RPC — Alchemy or Infura
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Oracle wallet private key — must have ORACLE_ROLE on CountersigReputation
# Generate a fresh wallet: cast wallet new
# Fund with Sepolia ETH for gas (each epoch write costs ~0.001 ETH)
# Grant ORACLE_ROLE via deployer:
#   cast send 0x0613C561C5003D7948Ea09dE2C1895965A5c3F27 \
#     "grantRole(bytes32,address)" \
#     $(cast keccak "ORACLE_ROLE") <ORACLE_WALLET_ADDRESS> \
#     --private-key <DEPLOYER_KEY> --rpc-url $RPC_URL
ORACLE_PRIVATE_KEY=0x...

# Contract addresses (Sepolia — from deployments/11155111.json)
IDENTITY_ADDRESS=0xD738A4cBe525d214f86059A8328786f072D6fbe1
REPUTATION_ADDRESS=0x0613C561C5003D7948Ea09dE2C1895965A5c3F27

# Epoch interval. Set to 1 for testnet fast feedback, 24 for production cadence.
EPOCH_HOURS=1

# HTTP port — bound to 127.0.0.1 only, not exposed publicly
PORT=3030

# Block to start scanning AgentRegistered events from.
# Set to the CountersigIdentity deploy block (find on Sepolia Etherscan) to avoid scanning from genesis.
FROM_BLOCK=0

# Max blocks per eth_getLogs call. Alchemy free tier: keep at 2000.
LOG_CHUNK_SIZE=2000
